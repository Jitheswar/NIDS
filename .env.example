# =============================================================================
# NIDS Environment Configuration
# Copy this file to .env and fill in the values before running docker compose up
# =============================================================================

# --- Database (MariaDB) ---
DB_ROOT_PASSWORD=change_me_root_password
DB_USER=nids
DB_PASSWORD=change_me_db_password

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- Keycloak ---
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin
KEYCLOAK_CLIENT_SECRET=change_me_client_secret

# --- Application ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# --- step-ca (Phase 2: mTLS) ---
STEP_CA_PASSWORD=change_me_step_ca_password
STEP_CA_FINGERPRINT=
MTLS_ENABLED=false

# --- Loki (Phase 2: Audit Logging) ---
# No secrets needed, Loki runs on internal network only

# --- Phase 3: Anomaly Detection ---
ANOMALY_DETECTION_ENABLED=true

# --- Phase 3: ZTNA ---
ZTNA_ENABLED=false

# --- Phase 3: Infisical (centralized secrets) ---
INFISICAL_ENCRYPTION_KEY=change_me_infisical_enc_key_hex_32bytes
INFISICAL_AUTH_SECRET=change_me_infisical_auth_secret
INFISICAL_TOKEN=

# --- Phase 3: Rotation Health Checks ---
ROTATION_CHECK_INTERVAL=3600

# --- SOPS (optional, for encrypted secrets) ---
# Generate an age key:  age-keygen -o secrets/age-key.txt
# Then set SOPS_AGE_KEY_FILE=secrets/age-key.txt
